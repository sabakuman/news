{
  "entities": {
    "User": {
      "title": "المستخدم",
      "description": "بيانات مستخدمي النظام",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "editor", "reviewer", "sector_approver", "final_approver", "viewer"] },
        "departmentId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["uid", "name", "email", "role", "status"]
    },
    "Department": {
      "title": "القطاع / الإدارة",
      "description": "قائمة القطاعات والإدارات",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "NewsItem": {
      "title": "خبر / مقال",
      "description": "بيانات الخبر وسير العمل الخاص به",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "departmentId": { "type": "string" },
        "content": { "type": "string" },
        "preparedBy": { "type": "string" },
        "internalReviewStatus": { "type": "string" },
        "sectorApprovalStatus": { "type": "string" },
        "finalApprovalStatus": { "type": "string" },
        "publishDate": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "review", "sector_approval", "final_approval", "ready", "published", "archived", "rejected"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "departmentId", "status", "createdBy", "createdAt"]
    },
    "Comment": {
      "title": "تعليق",
      "description": "التعليقات الداخلية على الأخبار",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "newsItemId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "newsItemId", "userId", "text", "createdAt"]
    },
    "Attachment": {
      "title": "مرفق",
      "description": "المرفقات المرتبطة بالخبر",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "newsItemId": { "type": "string" },
        "name": { "type": "string" },
        "currentVersionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "newsItemId", "name", "createdAt"]
    },
    "AttachmentVersion": {
      "title": "نسخة مرفق",
      "description": "تاريخ نسخ المرفقات",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "attachmentId": { "type": "string" },
        "newsItemId": { "type": "string" },
        "versionNumber": { "type": "integer" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["id", "attachmentId", "newsItemId", "versionNumber", "fileUrl", "uploadedBy", "uploadedAt"]
    },
    "ActivityLog": {
      "title": "سجل النشاط",
      "description": "سجل التغييرات والعمليات على الأخبار",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "newsItemId": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "previousStatus": { "type": "string" },
        "newStatus": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "newsItemId", "userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "مستخدمو النظام" },
    "/departments/{id}": { "schema": "Department", "description": "القطاعات والإدارات" },
    "/news_items/{id}": { "schema": "NewsItem", "description": "الأخبار والمقالات" },
    "/news_items/{newsItemId}/comments/{id}": { "schema": "Comment", "description": "تعليقات الخبر" },
    "/news_items/{newsItemId}/attachments/{id}": { "schema": "Attachment", "description": "مرفقات الخبر" },
    "/news_items/{newsItemId}/attachments/{attachmentId}/versions/{id}": { "schema": "AttachmentVersion", "description": "نسخ المرفق" },
    "/activity_logs/{id}": { "schema": "ActivityLog", "description": "سجل الأنشطة" }
  }
}
